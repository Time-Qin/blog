---
import { AUTHOR, TEST_LIST, TEST_TITLE } from "../../consts";
import "../../styles/global.css";

const title = TEST_TITLE;
const list = TEST_LIST
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <style>
            main {
                width: 960px;
                margin: 0 auto;
                padding: 2rem 1rem;
            }
            ul {
                display: flex;
                flex-direction: column;
                flex-wrap: wrap;
                gap: 2rem;
                list-style-type: none;
                margin: 0;
                padding: 0;
            }
            ul li {
                width: calc(50% - 1rem);
                background: #f8fafc;
                border-radius: 12px;
                padding: 1.5rem;
                box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
                transition: all 0.3s ease;
                border: 1px solid #e2e8f0;
            }
            ul li:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 15px rgba(0, 0, 0, 0.08);
                background: #ffffff;
            }
            ul li * {
                text-decoration: none;
                transition: 0.2s ease;
            }
            ul li:first-child .title {
                font-size: 2.369rem;
            }
            ul li a {
                display: block;
            }
            .title {
                margin: 0 0 1rem 0;
                color: #1e293b;
                line-height: 1.2;
            }
            .date {
                margin: 0;
                color: #64748b;
                font-size: 0.9rem;
            }
            ul li a:hover h4,
            ul li a:hover .date {
                color: #4338ca;
            }
            
            /* 开发信息样式 */
            .developer-info {
                margin-top: 2rem;
                padding: 1rem;
                background-color: #f1f5f9;
                border-radius: 8px;
                border-left: 4px solid #4338ca;
                font-size: 0.9rem;
                color: #475569;
            }
            
            .developer-info h3 {
                margin-top: 0;
                color: #1e293b;
            }
            
            .developer-info p {
                margin: 0.5rem 0;
            }
            
            .developer-info .intent {
                font-style: italic;
            }
            
            @media (max-width: 720px) {
                main {
                    width: 100%;
                    padding: 1rem 0.5rem;
                }
                ul {
                    gap: 1rem;
                }
                ul li {
                    width: 100%;
                    text-align: center;
                    padding: 1rem;
                }
                ul li:first-child .title {
                    font-size: 1.563em;
                }
            }
        </style>
    </head>
    <body>
        <main>
            <section>
                <ul>
                    {
                        list.map((post) => (
                            <li>
                                <a href={`/test${post.link}`}>
                                    <h4 class="title">{post.title}</h4>
                                    <p class="date">点击开始测试</p>
                                </a>
                            </li>
                        ))
                    }
                </ul>
                
                <!-- 开发人员和开发意图说明 -->
                <div class="developer-info">
                    <h3>相关信息</h3>
                    <p><strong>开发人员：</strong>{AUTHOR}</p>
                    <p class="intent"><strong>开发意图：</strong>为用户提供医学相关学科的在线测试功能，帮助用户检验学习成果。页面采用简洁直观的设计，便于用户快速找到并参与所需测试。</p>
                </div>
            </section>
        </main>
    </body>
</html>